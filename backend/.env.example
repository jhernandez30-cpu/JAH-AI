# Runtime
ENVIRONMENT=production
PORT=8000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
DATABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Auth providers
SUPABASE_GOOGLE_ENABLED=true
SUPABASE_APPLE_ENABLED=true

# Admin
OWNER_EMAIL=josuea.hernandezg@gmail.com
ADMIN_EMAILS=josuea.hernandezg@gmail.com

# Frontend / CORS
FRONTEND_URL=https://jah-ai.vercel.app
CORS_ALLOWED_ORIGINS=https://jah-ai.vercel.app

# LLM provider
MODEL_PROVIDER=
MODEL_NAME=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Local brain / runtime storage
TUTOR_IA_ROOT=
TUTOR_IA_PERSIST_DIR=
TUTOR_IA_OBSIDIAN_DIR=
TUTOR_IA_COLLECTION=conocimiento_fast
TUTOR_IA_JWT_SECRET=
TUTOR_IA_JWT_EXPIRES_SECONDS=604800

# Optional backend OAuth fallback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://jah-ai-bridge-production.up.railway.app/api/auth/google/callback

# Optional web search
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPAPI_API_KEY=
BRAVE_API_KEY=
BING_SEARCH_API_KEY=
WEB_SEARCH_TIMEOUT=12
